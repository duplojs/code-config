{
  "name": "@duplojs/code-config",
  "version": "0.0.0",
  "author": {
    "name": "ZeRiix",
    "url": "https://github.com/ZeRiix"
  },
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duplojs/code-config.git"
  },
  "scripts": {
    "build": "rolldown --config",
    "test:tu": "vitest --coverage",
    "test:tu:bench": "vitest bench",
    "test:tu:watch": "vitest --coverage --watch",
    "test:tu:update": "vitest --coverage --update",
    "test:types": "tsc -p tsconfig.test.json && npm -w integration run test:types",
    "test:lint": "oxlint --quiet",
    "test:lint:fix": "oxlint --fix --quiet",
    "prepare": "husky"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./oxlint": {
      "types": "./dist/oxlint/index.d.ts",
      "import": "./dist/oxlint/index.mjs",
      "require": "./dist/oxlint/index.cjs"
    },
    "./oxlint/plugin": {
      "types": "./dist/oxlint/plugin/index.d.ts",
      "import": "./dist/oxlint/plugin/index.mjs",
      "require": "./dist/oxlint/plugin/index.cjs"
    },
    "./commitlint": {
			"types": "./dist/commitlint/index.d.ts",
			"import": "./dist/commitlint/index.mjs",
			"require": "./dist/commitlint/index.cjs"
		},
    "./tsconfig.json": "./dist/tsconfig/tsconfig.json"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "10.7.0"
  },
  "peerDependencies": {
    "oxlint": ">=1.74.0 <2.0.0",
    "oxlint-tsgolint": ">=0.24.0 <1.0.0",
    "@commitlint/config-conventional": ">=21.2.0 <22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@duplojs/eslint": "0.5.0",
    "@types/node": "26.1.0",
    "husky": "9.1.7",
    "rolldown": "1.1.5",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-node-externals": "9.0.1",
    "unplugin-dts": "1.0.3",
    "@typescript/typescript6": "6.0.2",
    "tslib": "2.8.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "@vitest/coverage-istanbul": "4.1.10"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "workspaces": [
    "integration",
    "docs"
  ],
  "keywords": [
    "rules",
    "lint",
    "duplojs",
    "oxlint",
    "tsconfig"
  ],
  "engines": {
    "node": ">=22.18.0"
  }
}
